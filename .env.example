# SyncPulse Platform 環境変数サンプル
#
# `cp .env.example .env` でコピーし、必要に応じて値を上書きしてください。
# 値は将来の各サービス実装に合わせて更新される予定です。

# ---------- 共通 ----------
LOG_LEVEL=INFO

# ---------- metrics-collector (Python) ----------
METRICS_COLLECTOR_PORT=8000

# ---------- transformer (Go) ----------
TRANSFORMER_PORT=8080
TRANSFORMER_URL=http://localhost:8080

# ---------- dashboard-api (TypeScript) ----------
DASHBOARD_API_PORT=3000
DASHBOARD_API_URL=http://localhost:3000

# サービス間 URL（docker-compose 上ではホスト名を上書き予定）
METRICS_COLLECTOR_URL=http://localhost:8000
